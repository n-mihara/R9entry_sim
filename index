                areaName = 'その他・管外・不明';
            }

            let scoreVal = parseInt(row[scoreTypeCol]) || parseInt(row[keysMap.rawScore]) || 0;

            if (!areaStats[areaName]) {
                areaStats[areaName] = {
                    app: 0,
                    pass: 0,
                    enroll: 0,
                    scores: {}
                };
            }

            if (scoreVal >= 10 && scoreVal <= 27) {
                if (!areaStats[areaName].scores[scoreVal]) {
                    areaStats[areaName].scores[scoreVal] = { app: 0, pass: 0, enroll: 0 };
                }
            }

            areaStats[areaName].app++;
            if (scoreVal >= 10 && scoreVal <= 27) {
                areaStats[areaName].scores[scoreVal].app++;
            }

            let statusCol = headers.find(h => h === '合格発表時合否ST' || h.includes('合否ST') || h.includes('合否')) || '合格発表時合否ST';
