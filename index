<script>
    let rawData = [];
    let headers = [];
    let activeTab = 'report';
    let expandedAreas = new Set(); 
    
    // 来年度想定手続きの増減人数キャッシュ (各コース・区分別の手動アジャスト値、初期は0名)
    let simAdjustments = {};

    function getSimAdjustment(course, cat) {
        let key = course + '-' + cat;
        if (simAdjustments[key] === undefined) {
            simAdjustments[key] = 0;
        }
        return simAdjustments[key];
    }

    function updateSimAdjustment(course, cat, val) {
