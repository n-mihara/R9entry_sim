        statusMessage.classList.remove('hidden');
        statusMessage.innerHTML = '<span class="text-indigo-600 font-medium animate-pulse">CSVファイルを解析しています...</span>';
        
        const reader = new FileReader();
        reader.onload = function(evt) {
            let text = evt.target.result;
            
            // 【超堅牢・文字化け自動フォールバック】
            if (text.includes('\uFFFD')) {
                const sjisReader = new FileReader();
                sjisReader.onload = function(sjisEvt) {
                    processCSVText(sjisEvt.target.result);
                };
                sjisReader.readAsText(file, "Shift_JIS");
            } else {
                let firstChunk = text.slice(0, 100);
                if (!firstChunk.includes('性') && !firstChunk.includes('In') && !firstChunk.includes('在籍') && !firstChunk.includes('出願') && !firstChunk.includes('コ')) {
                    const sjisReader = new FileReader();
                    sjisReader.onload = function(sjisEvt) {
                        processCSVText(sjisEvt.target.result);
                    };
                    sjisReader.readAsText(file, "Shift_JIS");
                } else {
                    processCSVText(text);
                }
            }
        };
        reader.readAsText(file, "UTF-8");
    });

    // CSVのパースとクレンジング
    function processCSVText(text) {
        let parsed = Papa.parse(text, { skipEmptyLines: 'greedy' });
        let rows = parsed.data;
        
        if (!rows || rows.length === 0) {
            statusMessage.innerHTML = '<span class="text-rose-600 font-bold">CSVファイルが空か、読み取りに失敗しました。</span>';
            return;
        }

        let headerRowIndex = 0;
        let maxHits = -1;
        const keywords = ['性', '在籍', 'コース', '5科', '合格', '入学者', '受験番号'];
        
        for (let i = 0; i < Math.min(rows.length, 12); i++) {
            let hits = 0;
            rows[i].forEach(cell => {
                let cellStr = String(cell);
                keywords.forEach(kw => {
                    if (cellStr.includes(kw)) hits++;
                });
            });
            if (hits > maxHits) {
                maxHits = hits;
                headerRowIndex = i;
            }
        }

        // 列名のクレンジング（スペース、改行、ダブルクォーテーションを徹底除去）
        headers = rows[headerRowIndex].map((h, idx) => {
            return String(h).trim().replace(/[\s\r\n"\u200B]+/g, '');
        });

        // 受験生データのオブジェクト配列化
        rawData = [];
        for (let i = headerRowIndex + 1; i < rows.length; i++) {
            let r = rows[i];
            if (!r || r.length === 0 || (r.length === 1 && r[0] === '')) continue;
            
            let obj = {};
            headers.forEach((h, idx) => {
                let cellValue = r[idx] !== undefined ? String(r[idx]).trim() : '';
                obj[h] = cellValue.replace(/^["']|["']$/g, '').trim();
            });
            rawData.push(obj);
        }

        if (rawData.length === 0) {
            statusMessage.innerHTML = '<span class="text-rose-600 font-bold">生徒のデータ行を検出できませんでした。</span>';
            return;
        }

        setupAdjScoreSelectorOptions();

        statusMessage.innerHTML = '<span class="text-emerald-700 font-bold">✨ CSV読込完了（正常解析 / 受験生総数: ' + rawData.length + '名分）</span>';
        
        mainDashboard.classList.remove('hidden');
        setupFilterOptions();
        onCourseChange(); 
        onAreaCourseChange(); 
        runAdvancedSimulation(); 
    }

    // A, B, C, H, FD, FH, T の統合カテゴリ判別
    function getCategorizedType(row, currentCourseName) {
        let examTypeCol = headers.find(h => h.includes('入試区分')) || '入試区分';
        let examType = String(row[examTypeCol] || '').trim();
        let testCol = headers.find(h => h.includes('試験名')) || '試験名';
        let testName = String(row[testCol] || '').trim();
        
        if (currentCourseName.includes('アスリート')) {
            return 'T';
        }

        if (examType === 'A' || testName.includes('A推薦') || examType.includes('A推薦')) return 'A';
        if (examType === 'B' || testName.includes('B推薦') || examType.includes('B推薦')) return 'B';
        if (examType === 'C' || testName.includes('C推薦') || examType.includes('C推薦')) return 'C';
        if (examType === 'H' || examType.includes('併願優遇') || testName.includes('併願優遇')) return 'H';
        if (testName.includes('第一志望') || examType.includes('第一志望') || examType === 'FD' || testName.includes('FD')) return 'FD';
        if (testName.includes('併願') || examType.includes('併願') || examType === 'FH' || testName.includes('FH')) return 'FH';

        return 'その他';
    }

