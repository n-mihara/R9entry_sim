            if (targetCourse !== 'all' && rowCourse !== targetCourse) return false;
            if (targetType !== 'all' && row['_cleanExamType'] !== targetType) return false;
            
            let appCol = headers.find(h => h.includes('出願かどうか'));
            if (appCol && row[appCol] && !row[appCol].includes('出願')) return false;
            
            return true;
