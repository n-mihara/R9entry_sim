    // 🚀 来年度シミュレーターの実行エンジン（バグ完全改修版）
    function runAdvancedSimulation() {
        const validCategories = ['A', 'B', 'C', 'H', 'FD', 'FH', 'T'];
        const selectedAreaCourse = document.getElementById('advSimAreaCourseSelect') ? document.getElementById('advSimAreaCourseSelect').value : 'all';
        
        let advSimCourses = {
            '叡智': { capacity: 20, app: 0, pass: 0, enroll: 0, cats: {} },
            'ハイパー': { capacity: 140, app: 0, pass: 0, enroll: 0, cats: {} },
            'アドバンスト': { capacity: 320, app: 0, pass: 0, enroll: 0, cats: {} },
            'アグレッシブ': { capacity: 40, app: 0, pass: 0, enroll: 0, cats: {} },
            'アスリート': { capacity: 80, app: 0, pass: 0, enroll: 0, cats: {} }
        };

        // 各カテゴリの初期化
        Object.keys(advSimCourses).forEach(k => {
            validCategories.forEach(cat => {
                advSimCourses[k].cats[cat] = { app: 0, enroll: 0, adjustedApp: 0, adjustedEnroll: 0 };
            });
        });

        // 地区ごとの想定数ハッシュ
        let areaAdvStats = {};

        // 移行カウンターの初期化
        let migCount = { 1: 0, 2: 0, 3: 0, 4: 0 };

        // R8実績入学手続者
        let r8TotalActualEnrolled = 0;

        // 【超・頑健特定】列名部分一致のみを信頼し、固定インデックスの混入ズレによるエラーを完全回避
        let colAdv2 = headers.find(h => h.includes('アドバンスト2項目加点')) || headers.find(h => h.includes('アドバンスト') && h.includes('2項目')) || '5科';
        let colHyp1 = headers.find(h => h.includes('ハイパー1項目加点')) || headers.find(h => h.includes('ハイパー') && h.includes('1項目')) || '5科';
        let colAdv1 = headers.find(h => h.includes('アドバンスト1項目加点')) || headers.find(h => h.includes('アドバンスト') && h.includes('1項目')) || '5科';
        
        // 【重要】出願かどうか列と受験番号列の正確な特定
        let appCol = headers.find(h => h.includes('出願かどうか')) || '出願かどうか';
        let jukenCol = headers.find(h => h.includes('受験番号')) || '受験番号';
        let enrolledCol = headers.find(h => h === '入学者' || h.includes('入学者')) || '入学者';
        let statusCol = headers.find(h => h === '合格発表時合否ST' || h.includes('合否ST') || h.includes('合否')) || '合格発表時合否ST';
        let courseCol = headers.find(h => h === '出願コース' || h.includes('コース')) || '出願コース';

        // ----------------------------------------------------
        // 第一段階：移行・叡智新設・打切りロジックの適用 ＆ R8実績のカウント
        // ----------------------------------------------------
        rawData.forEach((row, index) => {
            // 文字化け・スペース対策を施した出願確認
            if (appCol && row[appCol] && !row[appCol].includes('出願')) return;

            let course = String(row[courseCol] || '').trim();
            let isEnrolled = row[enrolledCol] == '1' || String(row[enrolledCol]).includes('1');
            let st = row[statusCol] ? row[statusCol].trim() : '';
            let isPassed = st !== '' && !st.includes('不合格') && !st.includes('欠席') && !st.includes('XX') && st !== 'not_pass';

            let areaName = row[keysMap.area] ? row[keysMap.area].trim() : 'その他・管外・不明';
            if (areaName === '') areaName = 'その他・管外・不明';

            // コース割り当て
            let courseGroup = 'アドバンスト';
            if (course.includes('ハイパー')) courseGroup = 'ハイパー';
            else if (course.includes('アグレッシブ')) courseGroup = 'アグレッシブ';
            else if (course.includes('アスリート')) courseGroup = 'アスリート';

            let origCat = getCategorizedType(row, courseGroup);

            if (isEnrolled) r8TotalActualEnrolled++;

            // 地区別データ（R8実績）の初期化
            if (!areaAdvStats[areaName]) {
                areaAdvStats[areaName] = {
                    r8: { A: 0, B: 0, C: 0, H: 0, FD: 0, FH: 0, T: 0, totalApp: 0, enroll: 0 },
                    r9: { A: 0, B: 0, C: 0, H: 0, FD: 0, FH: 0, T: 0, totalApp: 0, enroll: 0 }
                };
            }

            // R8実績加算（アスリートAは特別枠Tとして計上除外）
            let r8CatForArea = origCat;
            if (courseGroup === 'アスリート' && origCat === 'A') {
                r8CatForArea = 'アスリート別枠'; 
            }

            // 地区別R8実績表示用の絞り込み対応
            let r8PassesCriteria = false;
            if (selectedAreaCourse === 'all') {
                r8PassesCriteria = true;
            } else if (selectedAreaCourse === '叡智') {
                r8PassesCriteria = false;
            } else {
                r8PassesCriteria = (courseGroup === selectedAreaCourse);
            }

            if (r8PassesCriteria) {
                if (validCategories.includes(r8CatForArea)) {
                    areaAdvStats[areaName].r8[r8CatForArea]++;
                }
                areaAdvStats[areaName].r8.totalApp++;
                if (isEnrolled) {
                    areaAdvStats[areaName].r8.enroll++;
                }
            }

            // 各種加点データの精密抽出（型エラーの安全フォールバック対応）
            let rawScoreCol = headers.find(h => h === '5科' || h.includes('5科')) || '5科';
            let rawScore5 = parseInt(row[rawScoreCol]) || 0; 
            
            let valAdv2 = parseInt(row[colAdv2]);
            // 0の場合も加点前5科評定を適用する（未該当時フォールバック）
            let scoreAdv2 = (isNaN(valAdv2) || valAdv2 === 0) ? rawScore5 : valAdv2;

            let valHyp1 = parseInt(row[colHyp1]);
            let scoreHyp1 = (isNaN(valHyp1) || valHyp1 === 0) ? rawScore5 : valHyp1;

            let valAdv1 = parseInt(row[colAdv1]);
            let scoreAdv1 = (isNaN(valAdv1) || valAdv1 === 0) ? rawScore5 : valAdv1;

            // R9移行処理変数の初期化
            let simCourse = courseGroup;
            let simCat = origCat;
            let simPassed = isPassed;
            let simEnrolled = isEnrolled;
            let isMigrated = false;

            // 再現可能なシード乱数判定
            let seed = parseInt(row[jukenCol]) || (index * 13 + 7);
            let randVal = (seed * 19 + 5) % 100; // 0〜99

            // アスリートはすべて新たな区分でTとし、合格・手続き100%
            if (courseGroup === 'アスリート') {
                simCourse = 'アスリート';
                simCat = 'T';
                simPassed = true;
                simEnrolled = true;
                isMigrated = true;
            }

            // 叡智コース新設移行: ハイパー出願者で加点前5科が24, 25の生徒
            if (!isMigrated && courseGroup === 'ハイパー' && (rawScore5 === 24 || rawScore5 === 25)) {
                simCourse = '叡智';
                isMigrated = true;
            }

            // １．アグレッシブB/H出願者の内、内申18以上の10%が、アドバンストAで出願。
            if (!isMigrated && courseGroup === 'アグレッシブ' && (origCat === 'B' || origCat === 'H') && scoreAdv2 >= 18) {
                if (randVal < 10) { 
                    simCourse = 'アドバンスト';
                    simCat = 'A';
                    simPassed = true; 
                    simEnrolled = true; 
                    isMigrated = true;
                    migCount[1]++;
                }
            }
            // ２．アグレッシブA出願者の内、内申18以上の全員(100%)が、アドバンストAで出願。
            else if (!isMigrated && courseGroup === 'アグレッシブ' && origCat === 'A' && scoreAdv2 >= 18) {
                simCourse = 'アドバンスト';
                simCat = 'A';
                simPassed = true;
                simEnrolled = true;
                isMigrated = true;
                migCount[2]++;
            }
            // ３．アドバンストB/H出願者の内、アド1項目加点後が19でかつ、ハイパー1項目加点後内申20以上の生徒の15%が、叡智AまたはハイパーAで出願。
            else if (!isMigrated && courseGroup === 'アドバンスト' && (origCat === 'B' || origCat === 'H') && scoreAdv1 === 19) {
                if (scoreHyp1 >= 20) {
                    if (randVal < 15) { 
                        if (rawScore5 === 24 || rawScore5 === 25) {
                            simCourse = '叡智';
                        } else {
                            simCourse = 'ハイパー';
                        }
                        simCat = 'A';
                        simPassed = true;
                        simEnrolled = true;
                        isMigrated = true;
                        migCount[3]++;
                    }
                }

                // ４．アドバンストB/H出願者の内、加点後内申19の生徒で（上記３以外）の10%が、アドバンストAで出願。
                if (!isMigrated) {
                    if (randVal >= 15 && randVal < 25) { 
                        simCourse = 'アドバンスト';
                        simCat = 'A';
                        simPassed = true;
                        simEnrolled = true;
                        isMigrated = true;
                        migCount[4]++;
                    }
                }

                // BJ加点後が19で、移行３・移行４のいずれにも選ばれなかったアドB/Hは全員「出願なし(除外)」
                if (!isMigrated) {
                    simCourse = 'なし';
                    simCat = 'なし';
                    simPassed = false;
                    simEnrolled = false;
                    isMigrated = true;
                }
            }

            // アドバンストB/Hの内、BJ加点後内申が18以下の者は全員「出願なし(除外)」
            if (!isMigrated && courseGroup === 'アドバンスト' && (origCat === 'B' || origCat === 'H') && scoreAdv1 <= 18) {
                simCourse = 'なし';
                simCat = 'なし';
                simPassed = false;
                simEnrolled = false;
                isMigrated = true;
            }

            // アグレッシブのA, B, Hが0名となる前提（他へ移行していない本来のアグA,B,H出願者を削除）
            let isAggEliminated = (courseGroup === 'アグレッシブ' && (origCat === 'A' || origCat === 'B' || origCat === 'H'));
            if (!isMigrated && isAggEliminated) {
                simCourse = 'なし';
                simCat = 'なし';
                simPassed = false;
                simEnrolled = false;
            }

            // R9（来年度予測）の一時割り当て格納
            row['_simCourse'] = simCourse;
            row['_simCat'] = simCat;
            row['_simPassed'] = simPassed;
            row['_simEnrolled'] = simEnrolled;
        });

        // ----------------------------------------------------
        // 第二段階：各コース×各区分の基本予測（調整前）集計
        // ----------------------------------------------------
        rawData.forEach(row => {
            if (appCol && row[appCol] && !row[appCol].includes('出願')) return;
            let simCourse = row['_simCourse'] || 'なし';
            let simCat = row['_simCat'] || 'skip';
            let simPassed = row['_simPassed'] === true;
            let simEnrolled = row['_simEnrolled'] === true;

            if (simCourse !== 'なし') {
                advSimCourses[simCourse].app++;
                if (validCategories.includes(simCat)) {
                    advSimCourses[simCourse].cats[simCat].app++;
                }

                // 基本（調整前）の手続カウントを計算
                if (simPassed && simEnrolled) {
                    advSimCourses[simCourse].enroll++;
                    if (validCategories.includes(simCat)) {
                        advSimCourses[simCourse].cats[simCat].enroll++;
                    }
                }
            }
        });

        // ----------------------------------------------------
        // 第三段階：手動「手続き調整（±名）」による出願調整率（±%）の自動逆算＆反映
        // ----------------------------------------------------
        Object.keys(advSimCourses).forEach(cName => {
            let data = advSimCourses[cName];
            let accumulatedApp = 0;
            let accumulatedEnrolled = 0;

            validCategories.forEach(cat => {
                let catData = data.cats[cat];
                let adjustEnrollDiff = getSimAdjustment(cName, cat);
                
                // 出願数調整率の逆算ロジック
                let computedAdjPct = 0;
                if (catData.enroll > 0) {
                    computedAdjPct = (adjustEnrollDiff / catData.enroll) * 100;
                } else if (adjustEnrollDiff > 0) {
                    // もともとの手続き想定数が0名で追加する場合は、無限大（計算不可）
                    computedAdjPct = 99999; 
                }

                // 出願数のアジャスト
                let adjustedApp = catData.app * (1 + (computedAdjPct / 100));
                catData.adjustedApp = Math.round(adjustedApp);

                // 手続き数のアジャスト
                let adjustedEnroll = catData.enroll + adjustEnrollDiff;
                catData.adjustedEnroll = Math.max(0, Math.round(adjustedEnroll)); // 負の数は予防

                accumulatedApp += catData.adjustedApp;
                accumulatedEnrolled += catData.adjustedEnroll;
            });

            data.app = accumulatedApp;
            data.enroll = accumulatedEnrolled; 
        });

        // ----------------------------------------------------
        // 第四段階：地区別マトリクスへの反映（手動出願調整後の係数を適用）
        // ----------------------------------------------------
        rawData.forEach(row => {
            if (appCol && row[appCol] && !row[appCol].includes('出願')) return;

            let simCourse = row['_simCourse'] || 'なし';
            let simCat = row['_simCat'] || 'skip';
            let simPassed = row['_simPassed'] === true;
            let simEnrolled = row['_simEnrolled'] === true;

            let areaName = row[keysMap.area] ? row[keysMap.area].trim() : '';
            if (areaName === '') {
                areaName = 'その他・管外・不明';
            }

            // 地区マトリクス：指定コースで絞り込み判定
            let passesAreaCriteria = false;
            if (selectedAreaCourse === 'all') {
                passesAreaCriteria = true;
            } else {
                passesAreaCriteria = (simCourse === selectedAreaCourse);
            }

            if (simCourse !== 'なし' && passesAreaCriteria) {
                // コース・カテゴリ別のアジャスト率を逆算して適用
                let baseEnroll = advSimCourses[simCourse].cats[simCat].enroll;
                let adjustEnrollDiff = getSimAdjustment(simCourse, simCat);
                let computedAdjPct = 0;
                if (baseEnroll > 0) {
                    computedAdjPct = (adjustEnrollDiff / baseEnroll) * 100;
                } else if (adjustEnrollDiff > 0) {
                    computedAdjPct = 99999;
                }

                let weight = 1 * (1 + (computedAdjPct / 100));

                if (validCategories.includes(simCat)) {
                    areaAdvStats[areaName].r9[simCat] += weight;
                }
                areaAdvStats[areaName].r9.totalApp += weight;

                if (simPassed && simEnrolled) {
                    areaAdvStats[areaName].r9.enroll += weight;
                }
            }
        });

        // 移行人数カウンターの反映
        document.getElementById('mig1Count').textContent = migCount[1] + ' 名';
        document.getElementById('mig2Count').textContent = migCount[2] + ' 名';
        document.getElementById('mig3Count').textContent = migCount[3] + ' 名';
        document.getElementById('mig4Count').textContent = migCount[4] + ' 名';

        // コース別の内訳予測カードのレンダリング
        const courseSimList = document.getElementById('advSimCourseList');
        courseSimList.innerHTML = '';
        
        let r9TotalEnrolled = 0;

        Object.keys(advSimCourses).forEach(cName => {
            let data = advSimCourses[cName];
            r9TotalEnrolled += data.enroll;

            const card = document.createElement('div');
            card.className = "bg-slate-50 border border-slate-200 rounded-xl p-4 flex flex-col justify-between text-xs";
            
            let catDetailList = [];
            validCategories.forEach(cat => {
                let catData = data.cats[cat];
                let savedDiffVal = getSimAdjustment(cName, cat);

                // 叡智のFDスロットなどを常に解放
                if (catData.app > 0 || savedDiffVal !== 0 || (cName === '叡智' && cat === 'FD')) {
                    let inputId = 'adjInput-' + cName + '-' + cat;
                    
                    // 出願調整率％の算出表示用
                    let pctLabel = "";
                    if (catData.enroll > 0) {
                        let pct = (savedDiffVal / catData.enroll) * 100;
                        pctLabel = (pct >= 0 ? '+' : '') + pct.toFixed(0) + '%';
                    } else if (savedDiffVal > 0) {
                        pctLabel = "***%"; // 0名からの増減は***表示
                    } else {
                        pctLabel = "0%";
                    }

                    catDetailList.push(
                        '<div class="flex flex-col py-1.5 border-b border-dashed border-slate-200">' +
                            '<div class="flex justify-between items-center mb-1">' +
                                '<span class="font-bold text-slate-600">' + cat + '想定:</span>' +
                                '<span class="text-slate-800 font-semibold">' + catData.adjustedApp + '名 <span class="text-[10px] text-indigo-600 font-bold">(' + catData.adjustedEnroll + ')</span></span>' +
                            '</div>' +
                            '<div class="flex justify-between items-center text-[10px] text-slate-500 mt-1">' +
                                '<span class="text-[9px] bg-slate-200 px-1 py-0.5 rounded text-slate-600 font-bold">調整率: ' + pctLabel + '</span>' +
                                '<div class="flex items-center gap-1">' +
                                    '<span>手続:</span>' +
                                    '<input type="number" id="' + inputId + '" value="' + savedDiffVal + '" onchange="updateSimAdjustment(\'' + cName + '\', \'' + cat + '\', this.value)" class="w-12 text-center border rounded bg-white text-indigo-700 font-bold focus:ring-1 focus:ring-indigo-400 focus:outline-none">' +
                                    '<span class="font-bold">名</span>' +
                                '</div>' +
                            '</div>' +
                        '</div>'
                    );
                }
            });

            if (catDetailList.length === 0) {
                catDetailList.push('<div class="text-slate-400 italic text-center py-2">想定出願者なし</div>');
            }

            card.innerHTML = `
                <div>
                    <div class="flex justify-between items-start border-b pb-2 mb-3">
                        <div>
                            <span class="text-[10px] font-bold text-indigo-700 block">R9想定</span>
                            <h5 class="text-sm font-bold text-slate-900">${cName}</h5>
                        </div>
                        <span class="text-[10px] bg-indigo-50 border border-indigo-200 text-indigo-700 px-2 py-0.5 rounded-full font-bold">
                            定員: ${data.capacity}名
                        </span>
                    </div>
                    <div class="space-y-1 mb-3">
                        <div class="flex justify-between text-[11px]">
                            <span class="text-slate-500">手続予測総数:</span>
                            <span class="font-extrabold text-slate-900 text-sm text-indigo-700">${data.enroll} 名</span>
                        </div>
                        <div class="flex justify-between text-[11px]">
                            <span class="text-slate-500">定員充足率:</span>
                            <span class="font-bold text-indigo-600">${((data.enroll / data.capacity) * 100).toFixed(0)}%</span>
                        </div>
                    </div>
                    <div class="space-y-1 bg-white p-2.5 rounded-lg border border-slate-100 font-medium">
                        <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wider block mb-1 border-b pb-0.5">区分 [出願数 ➔ 手続想定]</span>
                        ${catDetailList.join('')}
                    </div>
                </div>
            `;
            courseSimList.appendChild(card);
        });

        // 総合予測情報の反映
        document.getElementById('advSimTotalEnrolled').textContent = r9TotalEnrolled;
        let finalDiff = r9TotalEnrolled - r8TotalActualEnrolled;
        const totalDiffEl = document.getElementById('advSimTotalDiff');
        
        let diffText = '';
        if (finalDiff > 0) {
            totalDiffEl.className = "text-emerald-400 font-bold text-sm block mt-1";
            diffText = '前年度（R8）手続き実績比: +' + finalDiff + '名 増加予測';
        } else if (finalDiff < 0) {
            totalDiffEl.className = "text-rose-400 font-bold text-sm block mt-1";
            diffText = '前年度（R8）手続き実績比: ' + finalDiff + '名 減少予測';
        } else {
            totalDiffEl.className = "text-slate-400 text-sm block mt-1";
            diffText = '前年度（R8）手続き実績と同等';
        }
        totalDiffEl.textContent = diffText;

        // 地区別 A, B, C, H, FD, FH, T想定マトリクスのレンダリング
        const advSimTableBody = document.getElementById('advSimTableBody');
        advSimTableBody.innerHTML = '';

        let sortedAreas = Object.keys(areaAdvStats).sort((a, b) => areaAdvStats[b].r8.totalApp - areaAdvStats[a].r8.totalApp);
        
        let totals = { r8App: 0, r8Enroll: 0, r9A: 0, r9B: 0, r9C: 0, r9H: 0, r9FD: 0, r9FH: 0, r9T: 0, r9TotalApp: 0, r9Enroll: 0 };

        sortedAreas.forEach(area => {
            let stats = areaAdvStats[area];
            
            // 地区ごとの各区分における丸められた実表示数を算出
            let r9A_round = Math.round(stats.r9.A);
            let r9B_round = Math.round(stats.r9.B);
            let r9C_round = Math.round(stats.r9.C);
            let r9H_round = Math.round(stats.r9.H);
            let r9FD_round = Math.round(stats.r9.FD);
            let r9FH_round = Math.round(stats.r9.FH);
            let r9T_round = Math.round(stats.r9.T);

            // 【完全一致ロジック】全体の合計数は、各々の丸め込み値の単純和で構成
            let roundedTotalApp = r9A_round + r9B_round + r9C_round + r9H_round + r9FD_round + r9FH_round + r9T_round;
            let roundedEnroll = Math.round(stats.r9.enroll);

            totals.r8App += stats.r8.totalApp;
            totals.r8Enroll += stats.r8.enroll;
            totals.r9A += r9A_round;
            totals.r9B += r9B_round;
            totals.r9C += r9C_round;
            totals.r9H += r9H_round;
            totals.r9FD += r9FD_round;
            totals.r9FH += r9FH_round;
            totals.r9T += r9T_round;
            totals.r9TotalApp += roundedTotalApp;
            totals.r9Enroll += roundedEnroll;

            let diffEnroll = roundedEnroll - stats.r8.enroll;
            let diffEnrollStr = diffEnroll > 0 ? '+' + diffEnroll : String(diffEnroll);

            const tr = document.createElement('tr');
            tr.className = "hover:bg-slate-50 border-b border-slate-100 text-center";
            tr.innerHTML = `
                <td class="sticky-col px-4 py-3 font-semibold text-slate-800 bg-white text-left">${area}</td>
                <td class="px-2 py-3 border-l border-slate-100 font-medium text-slate-700 bg-indigo-50/10">${r9A_round} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-blue-50/10 font-medium text-slate-700">${r9B_round} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-teal-50/10 font-medium text-slate-700">${r9C_round} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-emerald-50/10 font-medium text-slate-700">${r9H_round} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-amber-50/10 font-medium text-slate-700">${r9FD_round} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-orange-50/10 font-medium text-slate-700">${r9FH_round} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-purple-50/10 font-bold text-purple-700">${r9T_round} 名</td>
                <td class="px-3 py-3 border-l border-slate-200 font-bold text-slate-800">
                    <span>${roundedTotalApp} 名</span>
                </td>
                <td class="px-4 py-3 border-l border-slate-200 bg-rose-50/20 font-bold text-rose-950">
                    <span>${roundedEnroll} 名</span>
                    <span class="text-xs block text-rose-500 font-medium">(${diffEnrollStr})</span>
                </td>
            `;
            advSimTableBody.appendChild(tr);
        });

        // 地区別合計手続き数の調整反映（完全一致処理）
        let totalDiffEnroll = totals.r9Enroll - totals.r8Enroll;
        let totalDiffEnrollStr = totalDiffEnroll > 0 ? '+' + totalDiffEnroll : String(totalDiffEnroll);

        const foot = document.getElementById('advSimTableFoot');
        foot.innerHTML = `
            <tr class="bg-slate-100 text-slate-900 font-bold">
                <td class="sticky-col px-4 py-3 text-left bg-slate-100">合計</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-indigo-50/30">${totals.r9A} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-blue-50/30">${totals.r9B} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-teal-50/30">${totals.r9C} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-emerald-50/30">${totals.r9H} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-amber-50/30">${totals.r9FD} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-orange-50/30">${totals.r9FH} 名</td>
                <td class="px-2 py-3 border-l border-slate-200 bg-purple-100/30 text-purple-900">${totals.r9T} 名</td>
                <td class="px-3 py-3 border-l border-slate-200">
                    <span>${totals.r9TotalApp} 名</span>
                </td>
                <td class="px-4 py-3 border-l border-slate-200 bg-rose-100/40 text-rose-950 text-base">
                    <span>${totals.r9Enroll} 名</span>
                    <span class="text-xs block text-rose-600 font-semibold">(${totalDiffEnrollStr})</span>
                </td>
            </tr>
        `;
    }

    // タブ切り替え
    function switchTab(tabId) {
        activeTab = tabId;
        const tabs = ['report', 'area', 'advancedSim'];
        tabs.forEach(t => {
            const btn = document.getElementById('tabBtn-' + t);
            const content = document.getElementById('tabContent-' + t);
            if (t === tabId) {
                btn.className = "px-5 py-3 font-bold text-sm border-b-2 border-indigo-600 text-indigo-600 transition-all flex items-center gap-2";
                content.classList.remove('hidden');
            } else {
                btn.className = "px-5 py-3 font-medium text-sm text-slate-500 border-b-2 border-transparent hover:text-slate-700 transition-all flex items-center gap-2";
                content.classList.add('hidden');
            }
        });

        if (tabId === 'report') {
            generateReport();
        } else if (tabId === 'area') {
            generateAreaReport();
        } else if (tabId === 'advancedSim') {
            runAdvancedSimulation();
        }
    }

    // 既存の基本ボーダーシミュレーター計算
    function runSimulation() {
        return;
    }
</script>
